# PitchSync Environment Variables
# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pitchsync

# JWT (generate strong secrets for production)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:5174

# Rate Limiting
RATE_LIMIT_MAX=200

# GitHub API (optional — increases rate limit from 60 to 5000 req/hr)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Frontend
VITE_API_URL=http://localhost:5000/api
